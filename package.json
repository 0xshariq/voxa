{
  "name": "@0xshariq/voxa",
  "version": "1.1.0",
  "description": "A modern HTTP client library built on native Fetch API with advanced features like caching, retry, and request deduplication.",
  "keywords": [
    "http",
    "http-client",
    "fetch",
    "axios",
    "request",
    "cache",
    "retry",
    "typescript"
  ],
  "homepage": "https://github.com/0xshariq/voxa#readme",
  "bugs": {
    "url": "https://github.com/0xshariq/voxa/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xshariq/voxa.git",
    "directory": "packages/voxa"
  },
  "license": "MIT",
  "author": "Sharique Chaudhary",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js",
      "default": "./dist/config/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx src/test.ts",
    "test": "tsx src/test.ts",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "redis": "^4.7.0",
    "uuid": "^13.0.0"
  }
}
