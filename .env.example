# Environment Configuration

# ===== HTTP Configuration =====
HTTP_TIMEOUT=5000
HTTP_BASE_URL=

# ===== Cache Configuration =====
# Caching is OPTIONAL - Voxa works perfectly without it
# Enable caching to improve performance for repeated requests

CACHE_ENABLED=false
CACHE_TTL=300000
CACHE_STORAGE=memory

# ===== Cache Backend Configuration =====
# Generic configuration that works with Redis, Memcached, or other cache services
# Only needed if CACHE_STORAGE=redis or CACHE_STORAGE=custom

# Option 1: Use Cache URL (recommended for cloud services)
# Works with: Redis Labs, Upstash, AWS ElastiCache, Memcached Cloud, etc.
CACHE_URL=your-cache-host.example.com:6379
CACHE_PASSWORD=your-cache-password

# Option 2: Use individual host/port (for local/self-hosted)
# CACHE_HOST=localhost
# CACHE_PORT=6379

# Cache Database/Namespace (for Redis: 0-15, default: 0)
CACHE_DB=0

# Legacy Redis-specific variables (still supported for backward compatibility)
# REDIS_PUBLIC_URL=redis-host.example.com:6379
# REDIS_PASSWORD=your-password
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=0

# ===== Queue Configuration =====
QUEUE_ENABLED=false
QUEUE_MAX_CONCURRENT=6

# ===== Retry Configuration =====
RETRY_COUNT=5
RETRY_DELAY=1000
RETRY_EXPONENTIAL_BACKOFF=true
